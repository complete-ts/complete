{
  "$schema": "https://raw.githubusercontent.com/complete-ts/complete/refs/heads/main/packages/complete-cli/schemas/markdownlint-cli2-config-schema-jsonc.json",

  "config": {
    "extends": "markdownlint-config-complete",
  },

  // We have to import them one at a time because Node.js cannot resolve the ".js" imports.
  "customRules": [
    "./packages/markdownlint-rule-complete/src/rules/extended-ascii.ts",
    "./packages/markdownlint-rule-complete/src/rules/no-bold-headers.ts",
    "./packages/markdownlint-rule-complete/src/rules/no-code-block-newlines.ts",
    "./packages/markdownlint-rule-complete/src/rules/no-cspell-words.ts",
    "./packages/markdownlint-rule-complete/src/rules/no-horizontal-rules.ts",
    "./packages/markdownlint-rule-complete/src/rules/no-image-alt-text.ts",
    "./packages/markdownlint-rule-complete/src/rules/no-redundant-links.ts",
    "./packages/markdownlint-rule-complete/src/rules/no-space-before-punctuation.ts",
    "./packages/markdownlint-rule-complete/src/rules/no-unconventional-code-blocks.ts",
  ],

  "ignores": ["**/node_modules", "packages/docs/docs"],
}
